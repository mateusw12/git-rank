PORT=3000

# BullMQ
ENABLE_BULLMQ=true

# Auth (JWT)
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_KEY_EXPIRES_IN_DAYS=90

# Cache
CACHE_PREFIX=git-rank
GITHUB_REPOS_CACHE_TTL_SECONDS=300
GITHUB_COMMITS_CACHE_TTL_SECONDS=600
GITHUB_COMMITS_FETCH_LIMIT=100
GITHUB_COMMITS_STATS_LIMIT=25
GITHUB_BATCH_EVALUATION_CONCURRENCY=4

# GitHub
GITHUB_TOKEN=

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_API_KEY=
OLLAMA_EVALUATION_CACHE_TTL_SECONDS=21600
OLLAMA_MODELS=llama3.1,llama3.2
OLLAMA_MODEL=llama3.1
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_OUTPUT_TOKENS=512
OLLAMA_MAX_REPOSITORIES=12
OLLAMA_MAX_TEXT_FIELD_LENGTH=120
