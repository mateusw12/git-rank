PORT=3000

# BullMQ
ENABLE_BULLMQ=true

# Auth (JWT)
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_KEY_EXPIRES_IN_DAYS=90

# Cache
CACHE_PREFIX=git-rank
GITHUB_REPOS_CACHE_TTL_SECONDS=300
GITHUB_COMMITS_CACHE_TTL_SECONDS=600
GITHUB_COMMITS_FETCH_LIMIT=100
GITHUB_COMMITS_STATS_LIMIT=25
GITHUB_BATCH_EVALUATION_CONCURRENCY=4

# GitHub
GITHUB_TOKEN=

# Gemini
GOOGLE_API_KEY=
GEMINI_EVALUATION_CACHE_TTL_SECONDS=21600
GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_MAX_REPOSITORIES=12
GEMINI_MAX_TEXT_FIELD_LENGTH=120
